# --- Keycloak ---
KC_ISSUER=http://localhost:8080/realms/pkce-demo
KC_CLIENT_ID=node-pkce-app
# Client PUBLIC => pas de secret (PKCE remplace le secret).
# Si vous passez le client en "confidential", renseignez KC_CLIENT_SECRET.
KC_CLIENT_SECRET=

# --- App ---
APP_BASE_URL=http://localhost:3000
APP_PORT=3000
REDIRECT_URI=http://localhost:3000/callback
POST_LOGOUT_REDIRECT_URI=http://localhost:3000/

# Secret de chiffrement du cookie de session (changez-le en prod)
SESSION_SECRET=change-me-please-32-chars-minimum
