{
  "realm": "google-idp",
  "displayName": "Google IdP Demo",
  "displayNameHtml": "<b>Google</b> IdP Demo",
  "enabled": true,
  "sslRequired": "external",
  "loginWithEmailAllowed": true,
  "registrationAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,

  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,

  "clients": [
    {
      "clientId": "google-demo-app",
      "name": "Google Demo App (Authorization Code + PKCE)",
      "description": "Client public pour tester le login via Google (Sign in with Google)",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "rootUrl": "http://localhost:3000",
      "baseUrl": "/",
      "redirectUris": ["http://localhost:3000/callback"],
      "webOrigins": ["http://localhost:3000"],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:3000/"
      },
      "defaultClientScopes": ["profile", "email", "roles", "web-origins"]
    }
  ],

  "identityProviders": [
    {
      "alias": "google",
      "displayName": "Google",
      "providerId": "google",
      "enabled": true,
      "trustEmail": true,
      "storeToken": false,
      "linkOnly": false,
      "hideOnLogin": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "clientId": "REMPLACER_PAR_GOOGLE_CLIENT_ID.apps.googleusercontent.com",
        "clientSecret": "REMPLACER_PAR_GOOGLE_CLIENT_SECRET",
        "defaultScope": "openid profile email",
        "syncMode": "IMPORT",
        "useJwksUrl": "true"
      }
    }
  ],

  "identityProviderMappers": [
    {
      "name": "email",
      "identityProviderAlias": "google",
      "identityProviderMapper": "oidc-user-attribute-idp-mapper",
      "config": {
        "syncMode": "INHERIT",
        "claim": "email",
        "user.attribute": "email"
      }
    },
    {
      "name": "first-name",
      "identityProviderAlias": "google",
      "identityProviderMapper": "oidc-user-attribute-idp-mapper",
      "config": {
        "syncMode": "INHERIT",
        "claim": "given_name",
        "user.attribute": "firstName"
      }
    },
    {
      "name": "last-name",
      "identityProviderAlias": "google",
      "identityProviderMapper": "oidc-user-attribute-idp-mapper",
      "config": {
        "syncMode": "INHERIT",
        "claim": "family_name",
        "user.attribute": "lastName"
      }
    }
  ],

  "internationalizationEnabled": true,
  "supportedLocales": ["fr", "en"],
  "defaultLocale": "fr"
}