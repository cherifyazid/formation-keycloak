{
  "realm": "globex-idp",
  "displayName": "Globex Identity Provider",
  "enabled": true,
  "sslRequired": "external",
  "loginWithEmailAllowed": true,

  "clients": [
    {
      "clientId": "org-demo-broker",
      "name": "Broker client used by org-demo realm",
      "enabled": true,
      "publicClient": false,
      "secret": "globex-broker-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://localhost:8080/realms/org-demo/broker/globex/endpoint"
      ]
    }
  ],

  "users": [
    {
      "username": "john",
      "enabled": true,
      "email": "john@globex.com",
      "firstName": "John",
      "lastName": "Globex",
      "emailVerified": true,
      "credentials": [
        { "type": "password", "value": "john", "temporary": false }
      ]
    }
  ]
}
